rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the requesting user is an Administrator
    // This reads the user's own account doc to check position.
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/accounts/$(request.auth.uid)).data.position == 'Administrator';
    }

    // User profiles — own data only
    match /accounts/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Sensor nodes — authenticated read; admin write only
    match /sensor_nodes/{nodeId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Sensor readings — authenticated read; no client writes (ESP32 goes via backend)
    match /sensor_readings/{readingId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Detection events — authenticated read/create; admin-only update/delete
    match /detection_events/{eventId} {
      allow read, create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // OTP store — FIX: no direct client access; server backend handles this
    match /auth_otp_store/{docId} {
      allow read, write: if false;
    }

    // System logs — authenticated read (own); admin reads all; no client writes
    match /system_logs/{logId} {
      allow read: if isAdmin();
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // Push subscriptions — own data only
    match /push_subscriptions/{subId} {
      allow read, create, delete: if request.auth != null &&
        request.auth.uid == resource.data.account_id;
    }

    // Push notifications — admin read; no direct client writes
    match /push_notifications/{notifId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Contact tickets — create by any authenticated; read/update own; admin reads all
    match /contact_tickets/{ticketId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (
        isAdmin() || resource.data.account_id == request.auth.uid
      );
      allow update: if request.auth != null &&
        resource.data.account_id == request.auth.uid;
      allow delete: if isAdmin();
    }

    // Login attempts — FIX: admin read only; public creates (server writes on login)
    match /login_attempts/{attemptId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if false;
    }

    // Data retention audit — admin only
    match /data_retention_audit/{auditId} {
      allow read, create: if isAdmin();
    }

    // Device key store — FIX: admin read only; no client writes (server manages keys)
    match /device_key_store/{keyId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Known devices — own data only
    match /known_devices/{deviceId} {
      allow read, create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        resource.data.account_id == request.auth.uid;
    }

    // Device login alerts — authenticated read/create
    match /device_login_alerts/{alertId} {
      allow read, create: if request.auth != null;
    }
  }
}
