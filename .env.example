# ============================================================
#  .env.example — FreshZone environment variables
#  Copy this file to .env and fill in real values.
#  NEVER commit .env to version control.
# ============================================================

# ── DATABASE ──────────────────────────────────────────────────
DB_HOST=YOUR_VALUE_HERE
DB_PORT=3306
DB_NAME=freshzone_db
DB_USER=YOUR_VALUE_HERE
DB_PASS=YOUR_VALUE_HERE

# ── APPLICATION ───────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── AUTHENTICATION ────────────────────────────────────────────
# Use a long random string — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=YOUR_VALUE_HERE

# ── CORS / FRONTEND ───────────────────────────────────────────
# Public URL of your Firebase-hosted frontend
FRONTEND_URL=https://freshzone.space

# Your Render backend URL (used in CORS allowed origins)
# Format: https://freshzone-xxxx.onrender.com
RENDER_BACKEND_URL=YOUR_VALUE_HERE

# ── ESP32 / SENSOR DEVICE AUTH ────────────────────────────────
ESP32_API_KEY=YOUR_VALUE_HERE
ALLOW_LEGACY_ESP32_KEY=false

# ── EMAIL DELIVERY ────────────────────────────────────────────
RESEND_API_KEY=YOUR_VALUE_HERE

# ── WEB PUSH NOTIFICATIONS ────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=YOUR_VALUE_HERE
VAPID_PRIVATE_KEY=YOUR_VALUE_HERE

# ── ADMIN ESCALATION ──────────────────────────────────────────
# Extra email to escalate unacknowledged alerts to (optional)
ADMIN_EMAIL=

# ── ERROR MONITORING (OPTIONAL) ───────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── LOG LEVEL ───────────────────────────────────────────────────
LOG_LEVEL=info   # Options: trace, debug, info, warn, error
