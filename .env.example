# ============================================================
#  .env.example — FreshZone environment variables
#  Copy this file to .env and fill in real values.
#  Never commit .env to version control.
# ============================================================

# ── DATABASE ─────────────────────────────────────────────────
# MySQL/MariaDB host (e.g. on Railway: the internal hostname)
DB_HOST=YOUR_VALUE_HERE

# MySQL port (default 3306)
DB_PORT=3306

# Database name
DB_NAME=freshzone_db

# Database username
DB_USER=YOUR_VALUE_HERE

# Database password
DB_PASS=YOUR_VALUE_HERE

# ── APPLICATION ───────────────────────────────────────────────
# Node environment — set to 'production' on Railway, 'development' locally
NODE_ENV=development

# Port the Express server listens on (Railway sets this automatically)
PORT=3000

# ── AUTHENTICATION ────────────────────────────────────────────
# Secret used to sign and verify JWT tokens — use a long random string
JWT_SECRET=YOUR_VALUE_HERE

# ── CORS / FRONTEND ───────────────────────────────────────────
# The public URL of your frontend (used in CORS allowed origins)
FRONTEND_URL=https://freshzone.space

# ── ESP32 / SENSOR DEVICE AUTH ────────────────────────────────
# Legacy API key accepted from ESP32 devices (only used when ALLOW_LEGACY_ESP32_KEY=true)
ESP32_API_KEY=YOUR_VALUE_HERE

# Set to 'true' to allow the legacy x-api-key header from ESP32 devices
# Set to 'false' to require per-device HMAC authentication only
ALLOW_LEGACY_ESP32_KEY=false

# ── EMAIL DELIVERY ────────────────────────────────────────────
# Resend API key for sending OTP and alert emails (https://resend.com)
RESEND_API_KEY=YOUR_VALUE_HERE

# ── WEB PUSH NOTIFICATIONS ────────────────────────────────────
# VAPID public key for browser push notifications
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=YOUR_VALUE_HERE

# VAPID private key for browser push notifications
VAPID_PRIVATE_KEY=YOUR_VALUE_HERE

# ── ERROR MONITORING (OPTIONAL) ───────────────────────────────
# Sentry DSN for server-side error tracking (leave blank to disable)
SENTRY_DSN=

# Fraction of transactions to send to Sentry for performance tracing (0.0 to 1.0)
SENTRY_TRACES_SAMPLE_RATE=0.1
